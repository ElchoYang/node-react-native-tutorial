{
  "info": {
    "name": "Node-RN Tutorial Day1",
    "description": "阶段作业1：Express + Sequelize + JWT 全栈接口测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "公开接口",
      "item": [
        {
          "name": "GET / 服务状态",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            }
          }
        },
        {
          "name": "POST 注册",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test\",\n  \"password\": \"123456\",\n  \"nickName\": \"小明\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "register"]
            }
          }
        },
        {
          "name": "POST 登录（自动保存 Token）",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.code === 200 && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('✅ Token 已保存:', res.data.token);",
                  "} else {",
                  "  console.log('❌ 登录失败:', res.msg);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "用户管理（需登录）",
      "item": [
        {
          "name": "GET 用户列表",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/list",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "list"]
            }
          }
        },
        {
          "name": "PUT 修改用户",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickName\": \"小明（已修改）\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "1"]
            }
          }
        },
        {
          "name": "DELETE 删除用户",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "2"]
            }
          }
        }
      ]
    },
    {
      "name": "任务管理（需登录）",
      "item": [
        {
          "name": "POST 新增任务",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"学习 JWT\",\n  \"content\": \"看完 Day1 的视频并完成作业\",\n  \"status\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/task/add",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "add"]
            }
          }
        },
        {
          "name": "GET 我的任务列表",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/task/list",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "list"]
            }
          }
        },
        {
          "name": "PUT 修改任务",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"学习 JWT（已完成）\",\n  \"status\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/task/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "1"]
            }
          }
        },
        {
          "name": "DELETE 删除任务",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/task/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "task", "1"]
            }
          }
        }
      ]
    }
  ]
}
